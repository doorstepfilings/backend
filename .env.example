# App Configuration
NODE_ENV=development
APP_NAME=DoorstepFilings
PORT=4000
API_PREFIX=api
FRONTEND_URL=http://localhost:3000

# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=doorstep_db
DB_USERNAME=db_user
DB_PASSWORD=db_password
DATABASE_URL="mysql://db_user:db_password@127.0.0.1:3306/doorstep_db"

# Security
JWT_SECRET=provide_a_secure_random_string
JWT_EXPIRES_IN=7d

# Mail Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM=your_email@gmail.com

# Payment Gateway
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=xxxx
