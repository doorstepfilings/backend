<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <title>Invoice {{ invoiceId }}</title>
    <style>
        @page {
            margin: 0;
        }

        * {
            box-sizing: border-box;
        }

        body {
            font-family: DejaVu Sans, sans-serif;
            font-size: 12px;
            color: #1e293b;
            margin: 0;
            padding: 0;
            background: #ffffff;
        }

        .page {
            padding: 40px;
        }

        .right {
            text-align: right;
        }

        .muted {
            color: #64748b;
        }

        .small {
            font-size: 10px;
        }

        .mt-1 {
            margin-top: 4px;
        }

        .mt-2 {
            margin-top: 8px;
        }

        .mt-3 {
            margin-top: 12px;
        }

        .header-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 40px;
        }

        .header-table td {
            vertical-align: top;
        }

        .company-name {
            font-size: 24px;
            font-weight: 800;
            color: #1e3a8a;
            margin: 0 0 8px 0;
            letter-spacing: -0.02em;
        }

        .invoice-title {
            font-size: 24px;
            font-weight: 800;
            color: #0f172a;
            margin: 0 0 8px 0;
            letter-spacing: -0.02em;
        }

        .header-text {
            font-size: 11px;
            line-height: 1.6;
            color: #334155;
        }

        /* Cards */
        .split-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 30px;
            table-layout: fixed;
        }

        .split-table td {
            vertical-align: top;
            width: 50%;
        }

        .card {
            border: 1px solid #e2e8f0;
            border-radius: 8px;
        }

        .card-header {
            background: #1e3a8a;
            color: #ffffff;
            padding: 10px 14px;
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            border-top-left-radius: 7px;
            border-top-right-radius: 7px;
        }

        .card-body {
            padding: 14px;
            background: #ffffff;
            font-size: 11px;
            line-height: 1.6;
            min-height: 80px;
            border-bottom-left-radius: 7px;
            border-bottom-right-radius: 7px;
        }

        .card-body-title {
            font-weight: 800;
            font-size: 12px;
            margin-bottom: 4px;
            color: #0f172a;
        }

        /* Items Table */
        .items-wrapper {
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            margin-bottom: 20px;
        }

        .items-table {
            width: 100%;
            border-collapse: collapse;
        }

        .items-table th {
            background: #1e3a8a;
            color: #ffffff;
            padding: 12px 14px;
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            text-align: left;
            font-weight: 700;
        }
        
        .items-table th:first-child {
            border-top-left-radius: 7px;
        }
        .items-table th:last-child {
            border-top-right-radius: 7px;
        }

        .items-table th.right {
            text-align: right;
        }

        .items-table td {
            padding: 12px 14px;
            border-bottom: 1px solid #e2e8f0;
            font-size: 11px;
        }

        .items-table tr:last-child td {
            border-bottom: none;
        }

        .items-table td.right {
            text-align: right;
        }

        /* Totals */
        .totals-wrap {
            width: 100%;
        }

        .totals-table {
            width: 280px;
            margin-left: auto;
            border-collapse: collapse;
        }

        .totals-table td {
            padding: 8px 14px;
        }

        .totals-table .k {
            text-align: right;
            color: #334155;
            font-size: 11px;
            font-weight: 600;
        }

        .totals-table .v {
            text-align: right;
            font-weight: 700;
            font-size: 11px;
            color: #0f172a;
        }

        .total-row td {
            background: #f1f5f9;
        }
        
        .total-row .k {
            color: #0f172a;
            font-size: 13px;
            font-weight: 800;
            border-top-left-radius: 6px;
            border-bottom-left-radius: 6px;
        }
        
        .total-row .v {
            font-size: 14px;
            font-weight: 800;
            border-top-right-radius: 6px;
            border-bottom-right-radius: 6px;
        }

        .footer {
            margin-top: 40px;
            border-top: 1px solid #e2e8f0;
            padding-top: 20px;
            text-align: center;
        }
    </style>
</head>

<body>
    <div class="page">
        <table class="header-table">
            <tr>
                <td>
                    <div class="company-name">DoorstepFilings</div>
                    <div class="header-text">
                        {{ company.addressLine1 }}<br>
                        {{ company.addressLine2 }}<br>
                        {{#if company.gstin}}GSTIN: {{ company.gstin }}<br>{{/if}}
                        {{#if company.email}}Email: {{ company.email }}<br>{{/if}}
                        {{#if company.phone}}Phone: {{ company.phone }}{{/if}}
                    </div>
                </td>
                <td class="right">
                    <div class="invoice-title">Tax Invoice</div>
                    <div class="header-text">
                        Invoice N: #{{ invoiceId }}<br>
                        Date: {{ date }}<br>
                        Order N: #{{ orderId }}<br>
                        Status: <strong>{{#if isPaid}}PAID{{else}}OPEN{{/if}}</strong>
                    </div>
                </td>
            </tr>
        </table>

        <table class="split-table">
            <tr>
                <td style="padding-right: 10px;">
                    <div class="card">
                        <div class="card-header">Billed To</div>
                        <div class="card-body">
                            <div class="card-body-title">{{ user.name }}</div>
                            {{#if user.address}}{{ user.address }}<br>{{/if}}
                            {{#if user.email}}{{ user.email }}<br>{{/if}}
                            {{#if user.phone}}{{ user.phone }}{{/if}}
                        </div>
                    </div>
                </td>
                <td style="padding-left: 10px;">
                    <div class="card">
                        <div class="card-header">Payment Details</div>
                        <div class="card-body">
                            <div class="card-body-title">{{ payment.provider }}</div>
                            Provider Order: {{ payment.providerOrderId }}<br>
                            Transaction ID: {{ payment.transactionId }}<br>
                            Status: {{ payment.status }}
                        </div>
                    </div>
                </td>
            </tr>
        </table>

        <div class="items-wrapper">
            <table class="items-table">
                <thead>
                    <tr>
                        <th style="width: 45%;">LINE ITEM</th>
                        <th class="right">BASE</th>
                        <th class="right">GST (18%)</th>
                        <th class="right">TOTAL</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each services}}
                    <tr>
                        <td>
                            <div style="font-weight: 700; color: #0f172a;">{{ this.name }}</div>
                            {{#if this.plan}}<div class="small muted mt-1">Plan: {{ this.plan }}</div>{{/if}}
                        </td>
                        <td class="right">&#8377;{{ this.basePrice }}</td>
                        <td class="right">&#8377;{{ this.gstAmount }}</td>
                        <td class="right">&#8377;{{ this.totalAmount }}</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>

        <div class="totals-wrap">
            <table class="totals-table">
                <tr>
                    <td class="k">Subtotal</td>
                    <td class="v">&#8377;{{ totals.baseAmount }}</td>
                </tr>
                <tr>
                    <td class="k">GST (18%)</td>
                    <td class="v">&#8377;{{ totals.gstAmount }}</td>
                </tr>
                <tr class="total-row">
                    <td class="k">Total</td>
                    <td class="v">&#8377;{{ totals.grandTotal }}</td>
                </tr>
            </table>
        </div>

        <div class="footer small muted">
            <div>All amounts are in INR. This invoice is computer-generated and does not require a signature.</div>
            {{#if company.email}}
                <div class="mt-1">
                    Need help? Email <strong>{{ company.email }}</strong>
                    {{#if company.phone}} | Call <strong>{{ company.phone }}</strong>{{/if}}
                </div>
            {{/if}}
        </div>
    </div>
</body>

</html>
